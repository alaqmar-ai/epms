# EPMS — environment variables
#
# Leave Supabase keys empty to keep the app running with the localStorage
# fallback adapter. Fill them in once a Supabase project exists.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — legacy Apps Script fallback (deprecated, kept for back-compat)
NEXT_PUBLIC_API_URL=
